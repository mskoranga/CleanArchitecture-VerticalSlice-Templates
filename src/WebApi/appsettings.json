{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "Seq": {
      "ServerUrl": "http://localhost:5341",
      "ApiKey": ""
    },
    "Loki": {
      "Uri": "http://localhost:3100"
    }
  },
  "ConnectionStrings": {
    "connection": "Server=localhost;Database=Book;Username=postgres;Password=postgres"
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "ForgeRock": {
    "Authority": "https://your-forgerock-tenant/am/oauth2/realms/root",
    "Audience": "your-api-audience",
    "IntrospectionEndpoint": "https://your-forgerock-tenant/am/oauth2/realms/root/introspect",
    "ClientId": "your-client-id",
    "ClientSecret": "your-client-secret",
    "EnableTokenCaching": true,
    "CacheDurationMinutes": 5
  },
  "FeatureManagement": {
    "KafkaEventPublishing": true,
    "SchemaValidation": false
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Producer": {
      "ClientId": "clean-architecture-producer",
      "Acks": "All"
    },
    "Consumer": {
      "GroupId": "clean-architecture-consumer-group",
      "AutoOffsetReset": "Earliest"
    }
  },
  "AllowedHosts": "*"
}
