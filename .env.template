# Environment Variables Template
# Copy this file to .env and update with your values

# PostgreSQL Configuration
POSTGRES_DB=Book
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Application Configuration
ASPNETCORE_ENVIRONMENT=Docker
ASPNETCORE_URLS=http://+:8080

# Seq Configuration (Optional)
SEQ_API_KEY=

# Grafana Configuration (Optional)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ForgeRock/Authentication (Update with your values)
FORGEROCK_AUTHORITY=https://your-forgerock-tenant/am/oauth2/realms/root
FORGEROCK_AUDIENCE=your-api-audience
FORGEROCK_CLIENT_ID=your-client-id
FORGEROCK_CLIENT_SECRET=your-client-secret

# Kafka Configuration (Optional)
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# Feature Flags
FEATURE_KAFKA_EVENT_PUBLISHING=false
FEATURE_SCHEMA_VALIDATION=false
